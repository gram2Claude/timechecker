# timechecker — пример переменных окружения. Скопируй в .env и заполни при необходимости.
# Все значения опциональны — есть разумные дефолты (см. timechecker/config.py).

# Корень Claude Code (по умолчанию ~/.claude)
# TIMECHECKER_CLAUDE_HOME=C:\Users\<user>\.claude

# Каталог транскриптов Claude (по умолчанию <claude_home>/projects)
# TIMECHECKER_CLAUDE_PROJECTS_DIR=

# Путь к секретам wgp (Plane/GitHub) — по умолчанию ~/.wgp/secrets.json
# TIMECHECKER_WGP_SECRETS=C:\Users\<user>\.wgp\secrets.json

# Репозиторий и ветки
# TIMECHECKER_GITHUB_REPO=gram2Claude/timechecker
# TIMECHECKER_TARGET_BRANCH=master
# TIMECHECKER_DEV_BRANCH=            # по умолчанию = имя пользователя Windows в нижнем регистре

# Идентификатор сотрудника (по умолчанию = имя пользователя ОС)
# TIMECHECKER_EMPLOYEE=

# Путь к БД SQLite (по умолчанию <claude_home>/timechecker/timechecker.db)
# TIMECHECKER_DB_PATH=

# Backend БД. По умолчанию SQLite. Postgres (Supabase) — ЯВНЫЙ opt-in одним из:
#   1) TIMECHECKER_BACKEND=postgres  + supabase_db_url в ~/.wgp/secrets.json
#   2) TIMECHECKER_DB_URL=postgresql://...   (полный DSN; имеет приоритет)
# Без этих переменных наличие supabase_db_url в secrets НЕ включает Postgres.
# TIMECHECKER_BACKEND=
# TIMECHECKER_DB_URL=

# Срок хранения сырья (дней), по умолчанию 30
# TIMECHECKER_RETENTION_DAYS=30

# Окно инкрементального сбора (дней): collect обрабатывает события не старше N дней
# (idempotent upsert; важно для Postgres по сети). По умолчанию 2. Флаг --full — полный пересбор.
# TIMECHECKER_COLLECT_LOOKBACK_DAYS=2

# Логи
# TIMECHECKER_LOG_LEVEL=INFO
# TIMECHECKER_JSON_LOGS=0

# Пароль роли бота tg_assistant_bot для `timechecker setup-bot-role` (E11). Только в env,
# НЕ в репозитории/SQL; минимум 24 символа [A-Za-z0-9]. Имя env можно сменить флагом
# --password-env. См. docs/RUNBOOK.md → «Интеграция TG Chat Assistant».
# TG_ASSISTANT_BOT_PASSWORD=
