# timechecker — пример переменных окружения. Скопируй в .env и заполни при необходимости.
# Все значения опциональны — есть разумные дефолты (см. timechecker/config.py).

# Корень Claude Code (по умолчанию ~/.claude)
# TIMECHECKER_CLAUDE_HOME=C:\Users\<user>\.claude

# Каталог транскриптов Claude (по умолчанию <claude_home>/projects)
# TIMECHECKER_CLAUDE_PROJECTS_DIR=

# Путь к секретам wgp (Plane/GitHub) — по умолчанию ~/.wgp/secrets.json
# TIMECHECKER_WGP_SECRETS=C:\Users\<user>\.wgp\secrets.json

# Репозиторий и ветки
# TIMECHECKER_GITHUB_REPO=gram2Claude/timechecker
# TIMECHECKER_TARGET_BRANCH=master
# TIMECHECKER_DEV_BRANCH=            # по умолчанию = имя пользователя Windows в нижнем регистре

# Идентификатор сотрудника (по умолчанию = имя пользователя ОС)
# TIMECHECKER_EMPLOYEE=

# Путь к БД SQLite (по умолчанию <claude_home>/timechecker/timechecker.db)
# TIMECHECKER_DB_PATH=

# Логи
# TIMECHECKER_LOG_LEVEL=INFO
# TIMECHECKER_JSON_LOGS=0
